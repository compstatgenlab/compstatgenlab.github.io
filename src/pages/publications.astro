---
<Page title="Publications" description="Publications from the Computational and Statistical Genomics lab">
  <div class="max-w-5xl mx-auto px-6 py-16">

    <p class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-teal-600 mb-3">Papers & preprints</p>
    <h1 class="font-serif text-4xl text-stone-900 font-normal mb-4">Selected publications</h1>
    <div class="w-10 h-0.5 bg-gradient-to-r from-blue-600 to-teal-500 mb-6"></div>
    <div class="flex gap-4 mb-14">
      <a href="https://orcid.org/0000-0002-7725-4813" target="_blank" rel="noopener"
        class="inline-flex items-center gap-1.5 font-mono text-xs border border-stone-200 text-stone-600 px-3 py-1.5 rounded hover:border-stone-400 no-underline transition-colors">
        ORCID ↗
      </a>
      <a href="https://scholar.google.com/citations?user=RubinacciS" target="_blank" rel="noopener"
        class="inline-flex items-center gap-1.5 font-mono text-xs border border-stone-200 text-stone-600 px-3 py-1.5 rounded hover:border-stone-400 no-underline transition-colors">
        Google Scholar ↗
      </a>
    </div>

    <div class="space-y-0 divide-y divide-stone-100">
      {publications.map(p => (
        <div class="py-7 grid grid-cols-[56px_1fr] gap-6 group">
          <div class="font-mono text-xs text-stone-400 pt-0.5">{p.year}</div>
          <div>
            <h3 class="font-sans font-medium text-stone-900 leading-snug mb-1.5 group-hover:text-blue-700 transition-colors">
              <a href={p.doi} target="_blank" rel="noopener" class="no-underline hover:underline">{p.title}</a>
            </h3>
            <p class="text-sm text-stone-500 mb-1">{p.authors}</p>
            <p class="text-sm text-teal-600 italic mb-2">{p.journal}</p>
            <div class="flex flex-wrap items-center gap-2">
              {p.tags.map(tag => (
                <span class="font-mono text-[0.6rem] px-1.5 py-0.5 bg-stone-100 text-stone-400 rounded">{tag}</span>
              ))}
              <a href={p.doi} target="_blank" rel="noopener"
                class="font-mono text-[0.62rem] text-blue-700 hover:underline no-underline ml-1">
                {p.doi.replace('https://doi.org/', 'doi:')} ↗
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="mt-10 text-sm text-stone-400">
      Full publication list available on <a href="https://orcid.org/0000-0002-7725-4813" target="_blank" class="text-blue-700 hover:underline no-underline">ORCID</a>.
    </p>
  </div>
</Page>
