---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// Pull latest articles for homepage
import { getCollection } from 'astro:content';
const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<Base title="Home" description="Computational and Statistical Genomics – Rubinacci Lab, FIMM, University of Helsinki">
  <Nav />

  <!-- ── HERO ───────────────────────────────────────────────────────── -->
  <section class="relative bg-white overflow-hidden">
    <!-- Subtle grid texture -->
    <div class="absolute inset-0 pointer-events-none"
      style="background-image: linear-gradient(#e7e5e4 1px, transparent 1px), linear-gradient(90deg, #e7e5e4 1px, transparent 1px); background-size: 52px 52px; mask-image: radial-gradient(ellipse 60% 100% at 75% 50%, black 20%, transparent 70%); opacity: 0.5;">
    </div>

    <div class="relative max-w-6xl mx-auto px-6 py-20 md:py-28 grid md:grid-cols-2 gap-12 items-center">
      
      <!-- TEXT COLUMN -->
      <div>
        <p class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-blue-700 mb-5 flex items-center gap-2">
          <span class="inline-block w-6 h-px bg-blue-700"></span>
          Rubinacci Lab · FIMM · University of Helsinki
        </p>

        <h1 class="font-serif text-4xl md:text-5xl xl:text-6xl text-stone-900 font-normal leading-[1.1] mb-6">
          Computational<br>&amp; <em class="text-blue-700">Statistical</em><br>Genomics
        </h1>

        <p class="text-stone-500 text-lg leading-relaxed max-w-md mb-8">
          We develop efficient statistical and computational methods to decode human genetic variation at scale — applying them to biobanks to understand the genetic basis of disease.
        </p>

        <div class="flex flex-wrap gap-3">
          <a href="/research" class="inline-flex items-center gap-2 bg-blue-700 text-white text-sm font-medium px-5 py-2.5 rounded-md hover:bg-blue-600 transition-colors no-underline">
            Our Research
          </a>
          <a href="/software" class="inline-flex items-center gap-2 border border-blue-700 text-blue-700 text-sm font-medium px-5 py-2.5 rounded-md hover:bg-blue-50 transition-colors no-underline">
            Software & Tools
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 border border-stone-200 text-stone-600 text-sm font-medium px-5 py-2.5 rounded-md hover:border-stone-400 transition-colors no-underline">
            Join the lab
          </a>
        </div>
      </div>

      <!-- PHOTO COLUMN -->
      <div class="relative">
        <img
          src="/images/lab/group-photo.jpg"
          alt="CompStatGen Lab group photo"
          class="w-full rounded-2xl shadow-xl object-cover object-top border border-stone-100"
          style="max-height: 480px;"
        />
        <div class="absolute -bottom-4 -right-4 w-16 h-16 rounded-full overflow-hidden border-4 border-white shadow-lg">
          <img src="/images/lab/spiral-logo.jpg" alt="Lab logo" class="w-full h-full object-cover" />
        </div>
        <p class="font-mono text-[0.62rem] text-stone-400 mt-4 text-center tracking-wider uppercase">
          The team at our lab retreat · Kirkkonummi, Finland · 2026
        </p>
      </div>
    </div>
  </section>

  <!-- ── RESEARCH THEMES ────────────────────────────────────────────── -->
  <section class="bg-stone-50 border-y border-stone-100 py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-teal-600 mb-3">What we study</p>
      <h2 class="font-serif text-3xl text-stone-900 font-normal mb-10">Research</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { icon: '🧬', title: 'Structural Variation & Disease', body: 'Large genomic rearrangements — deletions, duplications, inversions — shape disease risk. We integrate multi-omics data to decode their functional consequences at biobank scale.' },
          { icon: '🌍', title: 'Population Haplotypes & IBD', body: 'We identify shared haplotype segments across populations to illuminate human history and enable novel disease mapping via identity-by-descent analysis.' },
          { icon: '⚡', title: 'Scalable Algorithms', body: 'We design algorithms that process millions of genomes efficiently. Our tools have shaped multiple UK Biobank releases and are widely adopted globally.' },
          { icon: '🔬', title: 'Low-Coverage Imputation', body: 'lcWGS + imputation is now competitive with SNP arrays. We push accuracy to ultra-rare variants at coverages as low as 0.1× for under $1 per genome.' },
          { icon: '📊', title: 'Biobank-Scale Phasing', body: 'We phase rare and singleton variants accurately without family data — a longstanding barrier — enabling compound heterozygous disease detection.' },
          { icon: '🏥', title: 'Multi-Omics Integration', body: 'We integrate genetic variation with transcriptomics, proteomics, and other molecular layers to trace how genomic changes propagate to disease.' },
        ].map(r => (
          <div class="group bg-white rounded-xl border border-stone-100 p-6 hover:border-blue-200 hover:shadow-md transition-all cursor-default relative overflow-hidden">
            <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-blue-600 to-teal-500 scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300"></div>
            <div class="text-2xl mb-3">{r.icon}</div>
            <h3 class="font-serif text-stone-900 text-[1.05rem] mb-2">{r.title}</h3>
            <p class="text-stone-500 text-sm leading-relaxed">{r.body}</p>
          </div>
        ))}
      </div>
      <div class="mt-8">
        <a href="/research" class="font-mono text-xs text-blue-700 hover:underline no-underline">All our research →</a>
      </div>
    </div>
  </section>

  <!-- ── PHOTO + SOFTWARE (merged) ─────────────────────────────────── -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Top: photo left, text right -->
      <div class="grid md:grid-cols-2 gap-12 items-center mb-16">
        <div>
          <img
            src="/images/lab/eshg-2025.jpg"
            alt="Simone presenting at ESHG 2025"
            class="w-full rounded-2xl shadow-md border border-stone-100 object-cover"
            style="max-height: 400px; object-position: top;"
          />
          <p class="font-mono text-[0.62rem] text-stone-400 mt-3 tracking-widest uppercase text-center">
            ESHG 2025 · Milan, Italy
          </p>
        </div>
        <div>
          <p class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-teal-600 mb-3">Our work for the community</p>
          <h2 class="font-serif text-3xl text-stone-900 font-normal mb-5">Shaping the field with widely used, computationally efficient tools</h2>
          <p class="text-stone-500 leading-relaxed mb-4">We actively contribute through conference talks, workshops, and open-source software — presented at ESHG, ASHG, and other international conferences.</p>
          <p class="text-stone-500 leading-relaxed">Methods papers should be accompanied by robust, well-documented software usable by anyone — from large biobanks to individual labs with limited compute.</p>
        </div>
      </div>

      <!-- Software cards below -->
      <div class="grid md:grid-cols-3 gap-5">
        {[
          { name: 'GLIMPSE2', badge: 'lcWGS · Imputation', badgeColor: 'bg-teal-50 text-teal-700 border-teal-100', line: 'Biobank-scale low-coverage WGS imputation', body: 'We introduced a lcWGS imputation method that sublinearly to millions of haplotypes. Applied to 150,119 UK Biobank genomes.', href: 'https://odelaneau.github.io/GLIMPSE/' },
          { name: 'SHAPEIT5', badge: 'WGS · Phasing',      badgeColor: 'bg-blue-50 text-blue-700 border-blue-100',  line: 'Rare variant phasing at biobank scale',    body: 'Statistical phasing method that allows <5% switch error for ultra-rare variants.', href: 'https://odelaneau.github.io/shapeit5/' },
          { name: 'IMPUTE5',  badge: 'SNP Array · Imputation', badgeColor: 'bg-amber-50 text-amber-700 border-amber-100', line: 'Fast SNP array imputation via PBWT', body: 'Method allowing SNP array imputation scale to millions reference individuals.', href: 'https://jmarchini.org/software/' },
        ].map(t => (
          <div class="border border-stone-100 rounded-xl p-6 hover:shadow-md hover:border-stone-200 transition-all group relative overflow-hidden">
            <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-blue-600 to-teal-500 scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300"></div>
            <span class={`font-mono text-[0.62rem] tracking-widest uppercase px-2 py-0.5 rounded border ${t.badgeColor} inline-block mb-3`}>{t.badge}</span>
            <div class="font-serif text-2xl text-stone-900 mb-1">{t.name}</div>
            <div class="text-stone-400 text-sm italic mb-3">{t.line}</div>
            <p class="text-stone-500 text-sm leading-relaxed mb-4">{t.body}</p>
            <a href={t.href} target="_blank" rel="noopener" class="font-mono text-xs text-blue-700 hover:underline no-underline">Documentation →</a>
          </div>
        ))}
      </div>
      <div class="mt-6">
        <a href="/software" class="font-mono text-xs text-blue-700 hover:underline no-underline">All our software →</a>
      </div>

    </div>
  </section>
  <!-- ── ARTICLES + NEWS ────────────────────────────────────────────── -->
  <section class="bg-stone-50 border-t border-stone-100 py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-14">

        <!-- Left: latest articles -->
        <div>
          <p class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-teal-600 mb-3">From our blog</p>
          <h2 class="font-serif text-3xl text-stone-900 font-normal mb-8">Articles</h2>


          <div class="space-y-4">
            {articles.map(post => (
              <a href={`/articles/${post.slug}`} class="group block border border-stone-100 bg-white rounded-xl overflow-hidden hover:shadow-md hover:border-stone-200 transition-all no-underline">
                <div class="h-0.5 bg-gradient-to-r from-blue-600 to-teal-500 scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300"></div>
                <div class="p-5">
                  <div class="font-mono text-[0.62rem] text-stone-400 uppercase tracking-wider mb-1.5">
                    {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                    {post.data.tags?.[0] && <span class="ml-2 text-blue-600">· {post.data.tags[0]}</span>}
                  </div>
                  <h3 class="font-serif text-stone-900 text-base font-normal leading-snug mb-1.5 group-hover:text-blue-700 transition-colors">{post.data.title}</h3>
                  <p class="text-stone-500 text-sm leading-relaxed line-clamp-2">{post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
          <div class="mt-6">
            <a href="/articles" class="font-mono text-xs text-blue-700 hover:underline no-underline">All our blog articles →</a>
          </div>
        </div>

        <!-- Right: news feed -->
        <div>
          <p class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-teal-600 mb-3">Updates</p>
          <h2 class="font-serif text-3xl text-stone-900 font-normal mb-8">News</h2>
          <div class="relative">
            <div class="overflow-y-auto divide-y divide-stone-100 pr-1" style="max-height: 380px; scrollbar-width: thin; scrollbar-color: #d6d3d1 transparent;">
              {[
                { day: '05', month: 'Mar 2026', title: '📄 MetaGLIMPSE in AJHG', body: 'Kumar et al. introduces a method that allows to combine imputation of low-coverage data from multiple reference panels.', link: 'https://doi.org/10.1016/j.ajhg.2026.02.004', linkLabel: 'Read →' },
                { day: '07', month: 'Jan 2026', title: '👋 Welcome Francesca & Alisa', body: 'Dr. Francesca Rosamilia joins as a visiting postdoctoral researcher, and Alisa Willman starts her MSc thesis project with the sequencing unit.' },
                { day: '01', month: 'Jan 2026', title: '🎓 Théo transitions to Doctoral Researcher', body: 'Théo has been accepted to the doctoral school and secured 4 years of University of Helsinki funding. Congrats!' },
                { day: '24', month: 'Nov 2025', title: '🔬 Rotation: Sara Štebe', body: 'Sara Štebe joins the lab for a 3-month rotation project. Great to have you with us!' },
                { day: '01', month: 'Sep 2025', title: '🧬 Welcome Dr. Maarja Jõeloo', body: 'We are thrilled to welcome Dr. Maarja Jõeloo to the group as a Postdoctoral Researcher.' },
                { day: '19', month: 'May 2025', title: '📝 Marinella Laaksonen joins', body: 'Marinella joins the lab as a research assistant to work on her MSc thesis project.' },
                { day: '01', month: 'Apr 2025', title: '🤝 Théo Schneider joins as RA', body: 'The lab starts to grow! Théo Schneider joins the team as a Research Assistant.' },
                { day: '01', month: 'Sep 2024', title: '🚀 Rubinacci Lab launched', body: 'The group starts its journey at FIMM, University of Helsinki.' },
              ].map(n => (
                <div class="grid grid-cols-[60px_1fr] gap-4 py-4">
                  <div class="font-mono text-center shrink-0">
                    <span class="block font-serif text-lg text-stone-900 leading-none">{n.day}</span>
                    <span class="block text-[0.58rem] text-teal-600 uppercase tracking-wider mt-0.5">{n.month}</span>
                  </div>
                  <div>
                    <div class="font-medium text-stone-900 text-sm mb-0.5">{n.title}</div>
                    <div class="text-stone-500 text-sm leading-relaxed">{n.body}</div>
                    {n.link && (
                      <a href={n.link} class="font-mono text-xs text-blue-700 hover:underline no-underline mt-0.5 inline-block">{n.linkLabel}</a>
                    )}
                  </div>
                </div>
              ))}
            </div>
            <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-14 bg-gradient-to-t from-stone-50 to-transparent"></div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <Footer />
</Base>
